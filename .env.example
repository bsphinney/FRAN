# FRAN / DE-LIMP Corpus Browser — environment template.
# Copy to `.env` and fill in, OR just export these in your shell. NEVER commit real secrets
# (`.env`, `*.token`, `.pgfarm_token` are gitignored).
#
# Note: the app does not auto-load .env. To use this file:
#   set -a; source .env; set +a
#   uvicorn app.main:app --port 7860

# --- DB connection (PG Farm) — defaults are correct for the live corpus ---
DELIMP_PG_HOST=pgfarm.library.ucdavis.edu
DELIMP_PG_PORT=5432
DELIMP_PG_DB=uc-davis-genome-center-proteomics-core/delimp
DELIMP_PG_USER=genome-proteomics-service-account
DELIMP_PG_SSLMODE=require

# --- Credential: set ONE of these (do NOT commit the real value) ---
# DELIMP_PG_PASSWORD=<your 7-day PG Farm token>
# DELIMP_PG_TOKEN_FILE=/abs/path/to/.pgfarm_token

# --- Optional tuning ---
# DELIMP_PG_MAXCONN=6
# DELIMP_CACHE_TTL=20
# DELIMP_SLOW_CACHE_TTL=1800
